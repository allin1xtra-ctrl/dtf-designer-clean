{% liquid
  assign product_url = section.settings.product_url | default: '/products/custom-dtf-designer'
  assign query_joiner = '?'
  if product_url contains '?'
    assign query_joiner = '&'
  endif
  assign order_url = product_url | append: query_joiner | append: 'dtf_mode=transfer#dtf-designer'
%}

<style>
  #shopify-section-{{ section.id }} .dtf-value-section,
  #shopify-section-{{ section.id }} .dtf-process-section { margin: 20px auto 32px; padding: clamp(18px, 2.5vw, 28px); background: #fff; color: #0f172a; border: 1px solid #e2e8f0; border-radius: 22px; box-shadow: 0 14px 35px rgba(15,23,42,.08); }
  #shopify-section-{{ section.id }} .dtf-value-grid,
  #shopify-section-{{ section.id }} .dtf-process-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  #shopify-section-{{ section.id }} .dtf-value-card,
  #shopify-section-{{ section.id }} .dtf-process-card,
  #shopify-section-{{ section.id }} .dtf-inline-cta { background: linear-gradient(180deg, #f8fafc, #eef2ff); border: 1px solid #dbeafe; border-radius: 18px; padding: 16px; }
  #shopify-section-{{ section.id }} .dtf-section-kicker { margin: 0 0 8px; color: #2563eb; font-size: 12px; font-weight: 800; letter-spacing: .16em; }
  #shopify-section-{{ section.id }} .dtf-button { display: inline-flex; align-items: center; justify-content: center; padding: 12px 18px; border-radius: 999px; text-decoration: none; font-weight: 800; margin-top: 10px; background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; }
</style>

<section class="dtf-value-section page-width">
  <div class="dtf-section-header">
    <p class="dtf-section-kicker">{{ section.settings.kicker }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
  </div>

  <div class="dtf-value-grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        <article class="dtf-value-card" {{ block.shopify_attributes }}>
          <div class="dtf-value-icon">{{ block.settings.badge }}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    {% else %}
      <article class="dtf-value-card">
        <div class="dtf-value-icon">FAST</div>
        <h3>Fast production setup</h3>
        <p>Help buyers move from upload to checkout with a clean, simple ordering path.</p>
      </article>
      <article class="dtf-value-card">
        <div class="dtf-value-icon">BOLD</div>
        <h3>Retail-ready color</h3>
        <p>Showcase quality and confidence with premium visuals and trust-building content.</p>
      </article>
      <article class="dtf-value-card">
        <div class="dtf-value-icon">FLEX</div>
        <h3>Apparel and transfers</h3>
        <p>Support both garment customization and transfer-only orders from one product flow.</p>
      </article>
    {% endif %}
  </div>

  <div class="dtf-inline-cta">
    <div>
      <strong>{{ section.settings.cta_heading }}</strong>
      <span>{{ section.settings.cta_text }}</span>
    </div>
    <a href="{{ order_url }}" class="dtf-button dtf-button-primary">{{ section.settings.cta_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "DTF Pro benefits",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "WHY SHOP WITH YOUR FAVORITE DTF PLUG" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A Flora-ready storefront built for custom print sales" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Use these cards to sell speed, quality, and simplicity across Custom Drip, Custom Transfers, Gang Sheets, and Starter Packs." },
    { "type": "url", "id": "product_url", "label": "Designer product URL" },
    { "type": "text", "id": "cta_heading", "label": "CTA heading", "default": "Ready to place a custom order?" },
    { "type": "text", "id": "cta_text", "label": "CTA text", "default": "Launch the designer and send your job straight to checkout." },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "Start your order" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "settings": [
        { "type": "text", "id": "badge", "label": "Badge", "default": "FAST" },
        { "type": "text", "id": "title", "label": "Title", "default": "Quick ordering flow" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Send artwork, configure your product, and move into Shopify checkout with fewer steps." }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "DTF Pro benefits"
    }
  ]
}
{% endschema %}